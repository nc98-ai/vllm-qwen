user  nginx;
worker_processes  auto;
error_log  /var/log/nginx/error.log warn;
pid        /var/run/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Reduit les informations exposees par Nginx.
    server_tokens off;
    # Leger tampon au-dessus des 50 MB applicatifs pour les envois multipart.
    client_max_body_size 55M;

    # Limite de debit par IP pour limiter les abus sur l'API proxifiee.
    limit_req_zone $binary_remote_addr zone=api_limit:10m rate=60r/m;

    # Format de log utile pour tracer les appels proxifies et l'IP d'origine.
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for" '
                      'rt=$request_time uct=$upstream_connect_time '
                      'uht=$upstream_header_time urt=$upstream_response_time '
                      'ua="$upstream_addr" us="$upstream_status"';
    access_log  /var/log/nginx/access.log  main;

    sendfile        on;
    keepalive_timeout  65;

    # Definition du backend FastAPI. La cible est injectee via variable ou secret.
    upstream fastapi_upstream {
        server ${NGINX_BACKEND_UPSTREAM};
        keepalive 32;
    }

    server {
        listen ${NGINX_HTTP_LISTEN_PORT};
        server_name localhost;
        return 301 https://$host$request_uri;
    }

    server {
        listen ${NGINX_HTTPS_LISTEN_PORT} ssl;
        http2 on;
        server_name localhost;

        # Certificats TLS montes dans le conteneur.
        ssl_certificate     /etc/nginx/certs/server_fullchain.crt;
        ssl_certificate_key /etc/nginx/certs/server.key;
        # Protocoles explicitement limites a TLS 1.2 et 1.3.
        ssl_protocols TLSv1.2 TLSv1.3;
        # Suites de chiffrement restreintes pour TLS 1.2.
        ssl_ciphers ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
        # Suites de chiffrement explicites pour TLS 1.3.
        ssl_conf_command Ciphersuites TLS_AES_256_GCM_SHA384:TLS_AES_128_GCM_SHA256:TLS_AES_128_CCM_SHA256:TLS_CHACHA20_POLY1305_SHA256;
        ssl_prefer_server_ciphers on;
        # Reutilisation de session TLS pour limiter le cout des renegociations.
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 1d;

        # En-tetes de durcissement pour reduire l'exposition navigateur.
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header Permissions-Policy "accelerometer=(), autoplay=(), camera=(), display-capture=(), fullscreen=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), publickey-credentials-get=(), usb=()" always;
        add_header Cross-Origin-Opener-Policy "same-origin" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Referrer-Policy "no-referrer-when-downgrade" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Content-Security-Policy "default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'none'; font-src 'self'; object-src 'none'; manifest-src 'none'; worker-src 'none'; upgrade-insecure-requests" always;

        location / {
            # Laisse passer de petits pics sans ouvrir la porte aux floods.
            limit_req zone=api_limit burst=20 nodelay;

            proxy_pass http://fastapi_upstream;
            proxy_http_version 1.1;
            # Efface l'en-tete Connection pour conserver un keepalive propre vers l'upstream.
            proxy_set_header Connection "";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            # Propage des identifiants de correlation utiles au debug et aux logs app.
            proxy_set_header X-Request-ID $request_id;
            proxy_set_header X-Forwarded-Host $host;

            # Timeouts allonges pour les traitements IA et les requetes longues.
            proxy_read_timeout 300s;
            proxy_connect_timeout 300s;
            proxy_send_timeout 300s;

            # Evite qu'un probleme temporaire du backend coupe brutalement la reponse.
            proxy_next_upstream error timeout invalid_header http_502 http_503 http_504;
            proxy_next_upstream_tries 2;

            # Tampons explicites pour mieux absorber les reponses JSON volumineuses.
            proxy_buffering on;
            proxy_buffer_size 16k;
            proxy_buffers 8 16k;
            proxy_busy_buffers_size 32k;
        }

        error_page 413 /413.json;
        location = /413.json {
            default_type application/json;
            return 413 '{"error":"Fichier trop volumineux (Max 55MB)"}';
        }
    }
}
